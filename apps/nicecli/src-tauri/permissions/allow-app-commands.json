{
  "$schema": "../gen/schemas/permission.json",
  "identifier": "allow-app-commands",
  "description": "Allow invoking frontend application commands, including local runtime lifecycle commands",
  "allow": [
    "read_config_yaml",
    "update_config_yaml",
    "restart_local_runtime",
    "start_local_runtime",
    "open_settings_window",
    "open_login_window",
    "start_callback_server",
    "stop_callback_server",
    "save_files_to_directory",
    "check_auto_start_enabled",
    "enable_auto_start",
    "disable_auto_start"
  ]
}
